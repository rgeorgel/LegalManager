# ==============================================================================
# LegalManager — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores antes de rodar.
# NUNCA commite o arquivo .env no repositório.
# ==============================================================================

# ------------------------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=troque_esta_senha
POSTGRES_DB=legalmanager
POSTGRES_PORT=6632            # porta exposta no host (interna sempre 5432)

# ------------------------------------------------------------------------------
# API — ASP.NET Core
# ------------------------------------------------------------------------------
ASPNETCORE_ENVIRONMENT=Production   # Development | Staging | Production
API_PORT=6600                        # porta exposta no host (interna 8080)

# String de conexão montada automaticamente pelo docker-compose a partir das
# variáveis POSTGRES_* acima. Preencha manualmente se usar banco externo:
# DB_CONNECTION_STRING=Host=localhost;Port=5432;Database=legalmanager;Username=postgres;Password=troque_esta_senha

# ------------------------------------------------------------------------------
# JWT — Autenticação
# Gere uma chave forte: openssl rand -base64 48
# ------------------------------------------------------------------------------
JWT_KEY=TROQUE_ESTA_CHAVE_SECRETA_COM_NO_MINIMO_32_CARACTERES
JWT_ISSUER=LegalManager
JWT_AUDIENCE=LegalManagerUsers
# Duração dos tokens (opcional — padrão: 60min access, 7d refresh)
# JWT_ACCESS_TOKEN_MINUTES=60
# JWT_REFRESH_TOKEN_DAYS=7

# ------------------------------------------------------------------------------
# Frontend / CORS
# URL pública do frontend (usada em links de e-mail e CORS)
# ------------------------------------------------------------------------------
APP_FRONTEND_URL=http://localhost:6600

# ------------------------------------------------------------------------------
# Resend — E-mail transacional (https://resend.com)
# ------------------------------------------------------------------------------
RESEND_API_TOKEN=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@seudominio.com.br
RESEND_FROM_NAME=LegalManager

# ------------------------------------------------------------------------------
# Seq — Log estruturado (https://datalust.co/seq)
# ------------------------------------------------------------------------------
SEQ_PORT_API=6641    # porta da API de ingestão (interna 5341)
SEQ_PORT_UI=6681     # porta da UI web      (interna 80)
# SEQ_API_KEY=        # opcional — chave de API para autenticação no Seq

# ------------------------------------------------------------------------------
# Hangfire — Dashboard
# Proteja o dashboard em produção com usuário/senha
# ------------------------------------------------------------------------------
HANGFIRE_DASHBOARD_USER=admin
HANGFIRE_DASHBOARD_PASSWORD=troque_esta_senha

# ------------------------------------------------------------------------------
# OCI Object Storage — Armazenamento de documentos (Módulo 13)
# Guia: Identity → Users → <usuário> → Customer Secret Keys
# ------------------------------------------------------------------------------
OCI_NAMESPACE=seu_namespace_oci
OCI_REGION=sa-saopaulo-1
OCI_BUCKET_NAME=legal-manager-docs
OCI_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxx
OCI_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ------------------------------------------------------------------------------
# AbacatePay — Pagamentos PIX (Módulo 5)
# https://abacatepay.com — Dev mode disponível para testes
# ------------------------------------------------------------------------------
ABACATEPAY_API_KEY=abacate_live_xxxxxxxxxxxxxxxxxxxx
ABACATEPAY_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
# ABACATEPAY_BASE_URL=https://api.abacatepay.com/v2   # não alterar em produção

# ------------------------------------------------------------------------------
# IA / LLM — Integrações com IA (Módulo 10)
# Provedor: Anthropic (Claude) ou OpenAI
# ------------------------------------------------------------------------------
# Provedor da IA: "Anthropic" | "OpenAI"
IA_PROVIDER=Anthropic
# Chave da API do provedor selecionado
IA_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Modelo a ser utilizado
# Anthropic: claude-3-5-sonnet-latest | claude-3-haiku-latest
# OpenAI:   gpt-4o | gpt-4o-mini | gpt-4-turbo
IA_MODEL=claude-3-5-sonnet-latest
# Timeout em segundos para chamadas à API de IA (padrão: 30)
# IA_TIMEOUT_SECONDS=30
# URL base da API (opcional — útil para proxies ou ambientes on-premise)
# IA_BASE_URL=https://api.anthropic.com/v1
